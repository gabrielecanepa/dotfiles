[core]
  ignorecase = false
	pager = less -FRSX
[include]
  path = ~/.gitprofile

[init]
  defaultBranch = main
[branch]
	sort = -committerdate
[branch "main"]
  mergeoptions = --no-edit
[fetch]
	prune = true
	writeCommitGraph = true
[transfer]
	fsckObjects = true
[pull]
  rebase = true
[push]
	autoSetupRemote = true
	followTags = true
[commit]
  gpgsign = true
	verbose = true
[tag]
	gpgsign = true
[gpg]
  format = ssh
[column]
	ui = auto
[merge]
	conflictstyle = zdiff3
[rebase]
	autosquash = true
	autostash = true
	updateRefs = true
[rerere]
	enabled = true
[diff]
	algorithm = histogram
	colorMoved = dimmed-zebra
[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
  ui = true
[color "branch"]
  current = green
  remote = yellow
[advice]
  skippedCherryPicks = false
[help]
  autocorrect = 1

[filter "lfs"]
  clean = git-lfs clean -- %f
  process = git-lfs filter-process
  required = true
  smudge = git-lfs smudge -- %f

[alias]
  a = add
  acm = !git add -A && git commit -m
  aliases = !git config --get-regexp 'alias.*' | sed 's/alias.//'
  br = branch
  bsu = !git branch --set-upstream-to=origin $(git branch --show-current)
  ci = commit --interactive
  cm = commit -m
  co = checkout
  df = diff
  ds = diff --stat -r
  f = fetch
  fa = fetch --all
  fo = fetch origin
  fps = !git fetch --all && git pull --rebase && git sweep
  get = !git pull --rebase && git submodule update --init --recursive
  lg = log -10 --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
  lgg = log --graph --all --decorate --oneline
  log = log --color --graph
  p = push
  pf = push --force-with-lease
  psu = !git push --set-upstream origin $(git branch --show-current)
  pristine = !git reset --hard && git clean -df
  ps = !git pull && git sweep
  re = remote
  rv = remote -v
  rp = !git redo && git push
  rpf = !git redo && git push --force-with-lease
  redo = !git reset --soft HEAD^ && git add . && git commit -c ORIG_HEAD
  reset-origin = !git remote remove origin &>/dev/null && git remote add origin
  ro = reset-origin
  set-origin = !git branch --set-upstream-to=origin/$(git branch --show-current) $(git branch --show-current)
  so = set-origin
  st = status -sb
  sweep = !git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs -r git branch -D
  undo = reset --soft HEAD^
  unstage = reset HEAD --
	untrack = rm --cached --
  zip = !git archive HEAD -o $(basename $PWD).zip
