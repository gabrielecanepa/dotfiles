#!/usr/bin/env sh

alias ls="/bin/ls -GHhp"
alias ll="ls -la"
if command -v gls >/dev/null; then
  alias ls="gls -Hh --color --group-directories-first -I 'Icon'$'\r' -I .DS_Store -I .localized"
fi

# Sorts by size
lss() {
  { command -v gdu >/dev/null && gdu -L --si -d 1 "$@" || du -L -h -d 1 "$@"; } 2>/dev/null | sort -hr
}

# Remove directories recursively
rmm() {
  for folder in "$@"; do
    find . -type d -name "$folder" -prune -exec rm -rf {} \;
  done
}

# Create a directory and switch to it
mkdircd() {
  mkdir -pv "$1" && cd "$1" || return 1
}

# Create a directory and open it in VS Code
mkdircode() {
  mkdir -pv "$1" && code "$1" || return 1
}

# Directories
wd="$WORKING_DIR"
wdu="$WORKING_DIR/$USER"
tmp="$WORKING_DIR/.tmp"
cloud="$HOME/Library/Mobile Documents"
drive="$cloud/com~apple~CloudDocs"
downloads="$cloud/Downloads"
alias cdw="cd '$wd'"
alias cdwu="cd '$wdu'"
alias cdd="cd '$downloads'"
alias tmp="cd '$tmp'"
alias drive="cd '$drive'"

# Editor
alias home="$EDITOR $HOME"
alias aliases="$EDITOR $HOME/.aliases"
alias gitconfig="$EDITOR $HOME/.gitconfig"
alias zshrc="$EDITOR $HOME/.zshrc"
alias sshrc="$EDITOR $HOME/.ssh"
alias docs="$EDITOR \"$cloud/$(command ls "$cloud" | grep pro~writer)/Documents\""
alias te="open -a TextEdit"

# Shortcuts
alias hide="chflags hidden"
alias unhide="chflags nohidden"
alias rehistory="history >/dev/null"
alias fresh="lts install && brew fresh"

# CLIs
alias ghrv="gh repo view --web"
alias omzr="omz reload"
alias pn="pnpm"
alias pnx="pnpx"

# Git
_git_aliases() {
  for git_alias in $(git aliases | sed 's/ .*//'); do
    command -v "g$git_alias" >/dev/null || alias "g${git_alias}"="git $git_alias"
  done
  for workspace in $(find ~/.vscode -name "*.code-workspace" -not -path "*/extensions/*" 2>/dev/null); do
    alias "code-$(basename "$workspace" .code-workspace)"="code $workspace"
  done
  add-zsh-hook -d precmd _git_aliases
  unfunction _git_aliases
}
