#compdef lts

_lts() {
  emulate -L zsh

  if (( CURRENT == 2 )); then
    _alternative \
      'commands:command:((check\:"compare the active version against the latest LTS" install\:"install the latest LTS of one or more languages" i\:"alias for install"))' \
      "languages:language:(${_lts_langs[*]})"
    return
  fi

  case $words[2] in
    check) (( CURRENT == 3 )) && _values 'language' "${_lts_langs[@]}" ;;
    install|i) _values 'language' "${_lts_langs[@]}" ;;
  esac
}

_lts "$@"
