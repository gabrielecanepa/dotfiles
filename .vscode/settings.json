{
  "[instructions]": {
    "editor.formatOnSave": false
  },
  "chat.instructionsFilesLocations": {
    ".claude/rules": false,
    ".github/instructions": true
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "files.associations": {
    "*.json.lock": "jsonl",
    ".CFUserTextEncoding": "plaintext",
    ".aliases": "shellscript",
    ".gitprofile": "properties"
  },
  "files.exclude": {
    "*_history": true,
    ".DS_Store": true,
    ".Trash": true,
    "Applications": true,
    "Claude": true,
    "Desktop": true,
    "Developer": true,
    "Documents": true,
    "Downloads": true,
    "Library*": true,
    "Movies": true,
    "Music": true,
    "Pictures": true,
    "Public": true
  },
  "git.autoRepositoryDetection": false,
  "git.ignoredRepositories": [".oh-my-zsh"],
  "markdown.extension.toc.levels": "3..6",
  "oxc.enable.oxfmt": true,
  "search.exclude": {
    "**/*.code-search": true,
    "**/.claude": true,
    "**/.codex": true,
    "**/bower_components": true,
    "**/node_modules": true
  }
}
