{
  "files.associations": {
    ".aliases": "shellscript",
    ".CFUserTextEncoding": "plaintext",
    ".commitlintrc": "json",
    ".gitprofile": "properties",
    ".vscode/**/settings.json": "jsonc",
    "ignore": "ignore",
    "pre-commit": "shellscript",
    "pre-push": "shellscript"
  },
  "files.exclude": {
    "Applications": true,
    "Claude": true,
    "Desktop": true,
    "Developer": true,
    "Documents": true,
    "Downloads": true,
    "Library*": true,
    "Movies": true,
    "Music": true,
    "Pictures": true,
    "Public": true,
    ".Trash": true,
    ".DS_Store": true,
    "*_history": true
  },
  "search.exclude": {
    "**/.claude": true,
    "**/.codex": true,
    "**/bower_components": true,
    "**/node_modules": true,
    "**/*.code-search": true
  },
  "git.autoRepositoryDetection": false,
  "git.ignoredRepositories": [".oh-my-zsh"],
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.enable.oxfmt": true,
  "[instructions]": { "editor.formatOnSave": false },
  "markdown.extension.toc.levels": "3..6"
}
