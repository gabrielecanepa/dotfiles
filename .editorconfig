root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[[shell]]
switch_case_indent = true

[[bash]]
switch_case_indent = true

[{*.zsh,*.zsh-theme,.zshenv,.zshrc,.zprofile}]
ignore = true

[.zsh/**]
ignore = true
