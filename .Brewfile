tap "github/gh"
tap "homebrew/cask"
tap "homebrew/core"
tap "oven-sh/bun"
tap "supabase/tap"
tap "tw93/tap"
# YAML Parser
brew "libyaml"
# Data validation using Python type hints
brew "pydantic"
# CLI tool to build, test, debug, and deploy Serverless applications using AWS SAM
brew "aws-sam-cli"
