{
  "rules": {
    "type-enum": [2, "always", ["agents", "brew", "chore", "docs", "editor", "git", "node", "python", "ruby", "shell"]],
    "scope-enum": [2, "always", ["npm", "zsh"]],
    "type-case": [2, "always", "lower-case"],
    "type-empty": [2, "never"],
    "scope-case": [2, "always", "lower-case"],
    "subject-empty": [2, "never"]
  }
}
